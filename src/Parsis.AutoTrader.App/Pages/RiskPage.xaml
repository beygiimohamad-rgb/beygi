<Page x:Class="Parsis.AutoTrader.App.Pages.RiskPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <StackPanel Padding="28" Spacing="14" MaxWidth="900" HorizontalAlignment="Center"><TextBlock Text="مدیریت ریسک / Risk management" FontSize="30" FontWeight="Bold"/>
 <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="12"><ToggleSwitch x:Name="RiskToggle" Header="محاسبه حجم بر اساس درصد ریسک"/><TextBlock Text="حجم ثابت (Lot)"/><NumberBox x:Name="LotBox" SmallChange="0.01"/><TextBlock Text="درصد ریسک"/><NumberBox x:Name="RiskBox" SmallChange="0.1"/><TextBlock Text="حداکثر معاملات همزمان"/><NumberBox x:Name="MaxBox"/><ToggleSwitch x:Name="BreakEvenToggle" Header="پس از TP1 حد ضرر به نقطه ورود منتقل شود"/><Button Content="ذخیره" Click="Save_Click" Style="{StaticResource AccentButtonStyle}"/></StackPanel></Border></StackPanel>
</Page>
